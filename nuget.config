<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Test phase: the new AnalyseTool.Sdk (with PackExtension) is not on nuget.org yet.
         Locally: pack it from your AnalyzeTool clone into packages\ (see README).
         In CI: the release workflow packs it from the branch automatically. -->
    <add key="local-sdk" value="packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
